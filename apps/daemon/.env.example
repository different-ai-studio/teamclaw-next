# Copy this file to .env and fill in real values.
# Then run: source .env && cargo build
# Or use direnv: add "dotenv .env" to daemon/.envrc
#
# DO NOT commit .env — it is gitignored.

# Optional. Overrides the Cloud API endpoint that `amuxd init` POSTs the
# anonymous /v1/invites/claim request to. Defaults to https://cloud.ucar.cc.
# TEAMCLAW_CLOUD_API_URL=https://cloud.ucar.cc
