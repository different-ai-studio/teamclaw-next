<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name="android.permission.CAMERA"/>

    <!-- The microphone + camera permissions are dual-use (voice input,
         attachment capture). Mark the underlying hardware as optional so
         Google Play does not exclude tablets / ChromeOS devices that
         lack them. -->
    <uses-feature android:name="android.hardware.microphone" android:required="false"/>
    <uses-feature android:name="android.hardware.camera" android:required="false"/>

    <application
        android:name=".TeamclawApplication"
        android:label="Teamclaw"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.Teamclaw"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:supportsRtl="true">

        <!-- Disable Sentry's ContentProvider auto-init. We init from
             TeamclawApplication.onCreate so we can read SENTRY_DSN from
             BuildConfig and skip init entirely when it's blank (test
             builds, local dev with empty secrets.properties). -->
        <meta-data android:name="io.sentry.auto-init" android:value="false"/>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode|density|fontScale|locale|layoutDirection"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="teamclaw"/>
                <data android:scheme="amux"/>
            </intent-filter>
        </activity>
    </application>
</manifest>
